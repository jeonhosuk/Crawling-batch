# =============================================================================
# .env.example - 환경변수 템플릿
# 이 파일을 복사해서 .env로 만들고, 실제 값을 채워넣으면 됨
# .env는 git에 올라가지 않음 (.gitignore에 등록됨) - 비밀번호 보호용
# =============================================================================

DB_HOST=localhost           # DB 서버 주소
DB_PORT=3306                # DB 포트 (MariaDB 기본값 3306)
DB_USER=root                # DB 접속 계정
DB_PASSWORD=                # DB 비밀번호 (여기에 실제 비번 입력)
DB_NAME=cellar              # 사용할 데이터베이스 이름
CRON_INTERVAL_MINUTES=30    # 크롤링 주기 (분 단위, 30 = 30분마다)
